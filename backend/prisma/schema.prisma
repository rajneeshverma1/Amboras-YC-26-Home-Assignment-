generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  storeId   String   @map("store_id")
  eventType String   @map("event_type")
  timestamp DateTime @db.Timestamptz()
  data      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([storeId, timestamp(sort: Desc)])
  @@index([eventType])
  @@index([storeId, eventType])
  @@map("events")
}

model DailyMetrics {
  id                   String   @id @default(uuid())
  storeId              String   @map("store_id")
  date                 DateTime @db.Date
  totalRevenue         Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  totalPageViews       Int      @default(0) @map("total_page_views")
  totalAddToCart       Int      @default(0) @map("total_add_to_cart")
  totalRemoveFromCart  Int      @default(0) @map("total_remove_from_cart")
  totalCheckoutStarted Int      @default(0) @map("total_checkout_started")
  totalPurchases       Int      @default(0) @map("total_purchases")
  uniqueProductsSold   Int      @default(0) @map("unique_products_sold")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([storeId, date])
  @@index([storeId, date])
  @@map("daily_metrics")
}

model ProductMetrics {
  id            String   @id @default(uuid())
  storeId       String   @map("store_id")
  productId     String   @map("product_id")
  date          DateTime @db.Date
  revenue       Decimal  @default(0) @db.Decimal(12, 2)
  quantitySold  Int      @default(0) @map("quantity_sold")
  productName   String?  @map("product_name")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([storeId, productId, date])
  @@index([storeId, date])
  @@index([storeId, productId])
  @@map("product_metrics")
}
